{% if site.footer_fixed %}
  <footer class="fixed-bottom" role="contentinfo">
    <div class="container mt-0 footer-content">
      <span class="footer-copy">
        &copy; Copyright {{ site.time | date: '%Y' }}
        {{ site.first_name }}
        {{ site.middle_name }}
        {{ site.last_name }}. {{ site.footer_text }}
        {% if site.impressum_path %}
          <a href="{{ site.url }}{{ site.baseurl }}{{ site.impressum_path }}">Impressum</a>.
        {% endif %}
        {% if site.last_updated %}
          Last updated: {{ 'now' | date: '%B %d, %Y' }}.
        {% endif %}
      </span>
      {% if site.enable_visitor_counter and site.goatcounter_code %}
        <span
          class="visitor-counter"
          id="visitor-counter"
          style="position: fixed; right: 18px; bottom: 18px; z-index: 9999; display: inline-flex; align-items: center; gap: 0.3rem; padding: 0.45rem 0.7rem; border-radius: 999px; background: #111827 !important; color: #ffffff !important; border: 1px solid rgba(255, 255, 255, 0.22); box-shadow: 0 0.45rem 1.25rem rgba(0, 0, 0, 0.28); font-size: 0.78rem; font-weight: 600; line-height: 1; white-space: nowrap;"
        >
          Visitors: <span id="visitor-counter-value" style="color: #ffffff !important">...</span>
        </span>
      {% endif %}
    </div>
  </footer>
{% else %}
  <footer class="sticky-bottom mt-5" role="contentinfo">
    <div class="container footer-content">
      <span class="footer-copy">
        &copy; Copyright {{ site.time | date: '%Y' }}
        {{ site.first_name }}
        {{ site.middle_name }}
        {{ site.last_name }}. {{ site.footer_text }}
        {% if site.impressum_path %}
          <a href="{{ site.url }}{{ site.baseurl }}{{ site.impressum_path }}">Impressum</a>.
        {% endif %}
        {% if site.last_updated %}
          Last updated: {{ 'now' | date: '%B %d, %Y' }}.
        {% endif %}
      </span>
      {% if site.enable_visitor_counter and site.goatcounter_code %}
        <span
          class="visitor-counter"
          id="visitor-counter"
          style="position: fixed; right: 18px; bottom: 18px; z-index: 9999; display: inline-flex; align-items: center; gap: 0.3rem; padding: 0.45rem 0.7rem; border-radius: 999px; background: #111827 !important; color: #ffffff !important; border: 1px solid rgba(255, 255, 255, 0.22); box-shadow: 0 0.45rem 1.25rem rgba(0, 0, 0, 0.28); font-size: 0.78rem; font-weight: 600; line-height: 1; white-space: nowrap;"
        >
          Visitors: <span id="visitor-counter-value" style="color: #ffffff !important">...</span>
        </span>
      {% endif %}
    </div>
  </footer>
{% endif %}
